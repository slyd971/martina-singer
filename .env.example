# Airtable back office (optionnel — le site fonctionne sans)
AIRTABLE_TOKEN=           # Personal Access Token Airtable (lecture)
AIRTABLE_BASE_ID=         # ID de la base (ex: appXXXXXXXXXXXXXX)
AIRTABLE_REVALIDATE_SECONDS=60

# Noms de tables (optionnel — noms par défaut si vide)
AIRTABLE_TABLE_CLIENTS=Clients
AIRTABLE_TABLE_CONTACTS=Contacts
AIRTABLE_TABLE_SECTIONS=Sections
AIRTABLE_TABLE_GALLERY=Gallery Images
AIRTABLE_TABLE_VIDEOS=Videos

# Revalidation webhook (POST /api/revalidate?secret=xxx)
REVALIDATE_SECRET=        # Chaîne secrète partagée avec Airtable automation
